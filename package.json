{
    "name": "@thearturca/shared-configs",
    "version": "1.0.0",
    "private": false,
    "description": "personal configs for typescript, prettier and oxlint",
    "license": "MIT",
    "author": "thearturca - <arti.1046@gmail.com>",
    "type": "module",
    "exports": {
        "./prettier": "./prettier/index.mjs",
        "./oxlint": "./oxlint/base.json",
        "./tsconfig": "./tsconfig/base.json"
    },
    "files": [
        "prettier",
        "oxlint",
        "tsconfig"
    ],
    "scripts": {
        "fmt": "prettier --check .",
        "fmt:fix": "prettier --write .",
        "lint": "oxlint --config ./oxlint/base.json",
        "prepublishOnly": "pnpm run lint && pnpm run fmt"
    },
    "prettier": "./prettier/index.mjs",
    "dependencies": {
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "prettier-plugin-packagejson": "^3.0.2"
    },
    "devDependencies": {
        "oxlint": "^1.72.0",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@ianvs/prettier-plugin-sort-imports": "4.1.1",
        "oxlint": ">=0.7.0 <1",
        "prettier": ">=3.0.0 <4",
        "typescript": ">=5.0.0 <6"
    },
    "peerDependenciesMeta": {
        "oxlint": {
            "optional": true
        },
        "prettier": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "packageManager": "pnpm@10.18.0+sha256.3967a3efe2909df305fec4b833a304dfca17c380b6bb77672f4dac4f2cdd3788",
    "engines": {
        "node": ">=20"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/thearturca/shared-configs"
    }
}
